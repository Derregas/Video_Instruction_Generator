# =================================================================
# ШАБЛОН КОНФИГУРАЦИИ (.env.example)
# Скопируйте этот файл в .env и заполните своими данными.
# Файл .env НЕ ДОЛЖЕН попадать в систему контроля версий (Git)!
# =================================================================

# --- Секреты ---
# Получить ключ можно в Google AI Studio: https://aistudio.google.com/
# Пока не работает, возможно и не нужно будет
GEMINI_API_KEY=your_gemini_api_key_here

# --- Настройки LLM (Языковой модели) ---
# Имя модели Ollama (например: gemma4:e4b, gemma3:4b, llama3.1:8b)
# В src/modules/llm_processor.py подробно расписал свои тесты по разным моделям
LLM_MODEL=gemma4:e4b
# Размер контекста (обычно 8192 или 16384) 
# 8к не хватит
LLM_CONTEXT_SIZE=16384

# --- Настройки Аудио (Whisper) ---
# Размеры: tiny, base, small, medium, large-v3
# Оптимально использовать medium, но для тестов хватит small или base
WHISPER_MODEL=small
# Устройство: cuda (для NVIDIA GPU) или cpu
# На cpu достаточно медленно работает
WHISPER_DEVICE=cpu

# --- Отладка и Логирование ---
# Уровни: DEBUG, INFO, WARNING, ERROR 
# Можно пока забить
LOG_LEVEL=INFO
# Имя файла для сохранения промпта последнего запуска
LAST_DATA_FILE_NAME=last_data.txt
# Использовать ли кэшированные данные вместо обработки видео (True/False)
USE_LAST_DATA=False
