# ============================================================
# КОНФИГУРАЦИЯ ПРИЛОЖЕНИЯ Video Instruction Generator
# ============================================================
# Скопируйте этот файл в .env и отредактируйте параметры
#
# Использование:
#   cp .env.example .env
#   # затем отредактируйте значения в .env
# ============================================================

# DEBUG MODE
# true = подробный вывод, отключение некоторых оптимизаций
# false = production режим
DEBUG=false

# ============================================================
# WHISPER КОНФИГУРАЦИЯ (Распознавание речи)
# ============================================================

# Размер модели Whisper
# tiny    - самая маленькая, быстрая, но менее точная (~39М параметров)
# base    - сбалансированная (74М параметров) - рекомендуется
# small   - лучше точность (244М параметров)
# medium  - ещё лучше (769М параметров)
# large-v3 - лучшая точность (1550М параметров)
# ВНИМАНИЕ: Требует GPU для больших размеров!
WHISPER_MODEL_SIZE=base

# Устройство для вычислений
# cuda = GPU (намного быстрее, требует NVIDIA GPU + CUDA)
# cpu  = процессор (медленнее, работает везде)
WHISPER_DEVICE=cuda

# Тип вычислений (автоматический, если не указано)
# float16  = быстрее, меньше памяти (для GPU)
# float32  = стандартный, больше памяти
# int8     = квантизация (меньше памяти)
# int8_float32 = гибридный
WHISPER_COMPUTE_TYPE=float16

# Параметр beam search для транскрипции
# 1   = самый быстрый, менее точный
# 5   = сбалансированный (по умолчанию)
# 10+ = медленнее, более точный
WHISPER_BEAM_SIZE=5

# Язык транскрипции (опционально)
# Если не указано, язык определяется автоматически
# Примеры: en (английский), ru (русский), fr (французский), de (немецкий)
# Оставьте пустым для auto-detect
WHISPER_LANGUAGE=

# ============================================================
# VIDEO КОНФИГУРАЦИЯ (Обработка видео)
# ============================================================

# Поддерживаемые форматы видео (через запятую)
# По умолчанию: mp4,avi,mov,mkv,flv,wmv
VIDEO_SUPPORTED_FORMATS=mp4,avi,mov,mkv,flv,wmv

# Максимальный размер видеофайла в ГБ
# Используется для валидации входного файла
VIDEO_MAX_FILE_SIZE_GB=10.0

# FPS для извлечения кадров (опционально)
# Если не указано, используются все кадры
# Пример: 1 = 1 кадр в секунду, 30 = 30 кадров в секунду
VIDEO_EXTRACT_FPS=

# ============================================================
# AUDIO КОНФИГУРАЦИЯ (Обработка аудио)
# ============================================================

# Частота дискретизации аудио в Гц
# 16000 Hz = стандарт для речи (рекомендуется)
# 44100 Hz = стандарт для музыки
AUDIO_SAMPLE_RATE=16000

# Количество каналов аудио
# 1 = моно (рекомендуется для речи)
# 2 = стерео
AUDIO_CHANNELS=1

# ============================================================
# PROCESSING КОНФИГУРАЦИЯ (Обработка и задачи)
# ============================================================

# Директория для временных файлов
# По умолчанию: ./temp (в корне проекта)
PROCESSING_TEMP_DIR=./temp

# Удалять ли временные файлы после обработки
# true  = очищать диск (рекомендуется)
# false = сохранять для отладки
PROCESSING_CLEANUP_TEMP=true

# Максимальное количество параллельных обработчиков
# 1-2 для слабых ПК
# 4-8 для среднего ПК
# 8-16 для мощных серверов
PROCESSING_MAX_WORKERS=2

# Timeout для одной задачи обработки в секундах
# 3600 = 1 час
# Увеличьте для больших видео
PROCESSING_TIMEOUT_SECONDS=3600

# ============================================================
# LOGGING КОНФИГУРАЦИЯ (Логирование)
# ============================================================

# Уровень логирования
# DEBUG   = максимум информации (для разработки)
# INFO    = основная информация (рекомендуется)
# WARNING = только предупреждения и ошибки
# ERROR   = только ошибки
# CRITICAL = только критические ошибки
LOGGING_LEVEL=INFO

# Путь к файлу логов
LOGGING_FILE_PATH=./generator.log

# Логировать ли в файл
LOGGING_ENABLE_FILE_LOGGING=true

# Логировать ли в консоль
LOGGING_ENABLE_CONSOLE_LOGGING=true

# ============================================================
# ПРИМЕРЫ КОНФИГУРАЦИЙ
# ============================================================

# ДЛЯ БЫСТРОЙ ОБРАБОТКИ (на среднем ПК):
# WHISPER_MODEL_SIZE=base
# WHISPER_DEVICE=cuda
# WHISPER_BEAM_SIZE=3
# PROCESSING_MAX_WORKERS=2

# ДЛЯ ТОЧНОСТИ (требует мощный GPU):
# WHISPER_MODEL_SIZE=large-v3
# WHISPER_DEVICE=cuda
# WHISPER_BEAM_SIZE=10
# PROCESSING_MAX_WORKERS=1

# ДЛЯ CPU (медленно, но работает везде):
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# WHISPER_MODEL_SIZE=base
# PROCESSING_MAX_WORKERS=1
# PROCESSING_TIMEOUT_SECONDS=7200  # 2 часа
